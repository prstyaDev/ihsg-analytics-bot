# Telegram
TELEGRAM_BOT_TOKEN=

# GoAPI (IDX Stock Data)
GOAPI_KEY=

# AI Providers
# Primary AI Provider: Custom Aggregator (https://lite.koboillm.com)
AGGREGATOR_API_KEY=
AGGREGATOR_BASE_URL=https://lite.koboillm.com/v1
AGGREGATOR_MODEL=openai/gpt-4o

# Fallback AI Provider: Google Gemini (used when Aggregator fails/rate limited)
GOOGLE_GENERATIVE_AI_API_KEY=

# Supabase (PostgreSQL Database)
# [WAJIB] Project URL dari Supabase Dashboard → Settings → API
SUPABASE_URL=

# [WAJIB] Service Role Key dari Supabase Dashboard → Settings → API
# ⚠️ RAHASIA! Jangan expose ke client-side. Hanya untuk backend server.
# Service role key bypass Row Level Security untuk operasi admin.
SUPABASE_SERVICE_ROLE_KEY=

# Server
PORT=3000
NODE_ENV=development

# ============================================
# ALERT WORKER CONFIGURATION
# ============================================
# Alert check interval in milliseconds (how often to check active price alerts)
# Recommended range: 60000-300000ms (1-5 minutes)
# Default: 120000ms (2 minutes)
# 
# Lower values:
#   - More responsive alerts (faster notifications)
#   - Higher GoAPI usage (more frequent price checks)
#   - Increased server load
# 
# Higher values:
#   - Reduced API calls (lower costs)
#   - Slower alert responses (delayed notifications)
#   - Lower server resource usage
ALERT_CHECK_INTERVAL_MS=120000
